# Copia este archivo a .env.prod y ajusta valores para tu entorno
SPRING_PROFILES_ACTIVE=prod
DB_URL=jdbc:postgresql://localhost:5432/micuota
DB_USERNAME=micuota
DB_PASSWORD=micuota

# SMTP (opcional para enviar mails reales de pago)
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@micuota.online
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true

# Para pruebas locales con Mailpit puedes usar:
# MAIL_HOST=localhost
# MAIL_PORT=1025
# MAIL_SMTP_AUTH=false
# MAIL_SMTP_STARTTLS=false

# Integraciones de links de pago (Stripe, Square, Plexo)
# Si queda en false, el backend usa checkout sandbox interno para estos providers.
APP_PAYMENTS_EXTERNAL_PROVIDERS_ENABLED=false

# Stripe Payment Links
APP_PAYMENTS_STRIPE_SECRET_KEY=

# Square Payment Links
APP_PAYMENTS_SQUARE_ACCESS_TOKEN=
APP_PAYMENTS_SQUARE_LOCATION_ID=
APP_PAYMENTS_SQUARE_USE_SANDBOX=true

# Plexo Links (endpoint configurable)
APP_PAYMENTS_PLEXO_API_URL=
APP_PAYMENTS_PLEXO_API_KEY=

# Prometeo sandbox
APP_PROMETEO_ENABLED=true
APP_PROMETEO_SANDBOX=true
APP_PROMETEO_BASE_URL=https://account-validation.sandbox.prometeoapi.com
APP_PROMETEO_API_KEY=
APP_PROMETEO_CONNECT_TIMEOUT_MS=5000
APP_PROMETEO_READ_TIMEOUT_MS=15000

# n8n (automation)
N8N_TIMEZONE=America/Montevideo
N8N_HOST=localhost
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin123
N8N_ENCRYPTION_KEY=change-this-local-key

# n8n SMTP fake (Mailpit local por defecto)
N8N_EMAIL_MODE=smtp
N8N_SMTP_HOST=mailpit
N8N_SMTP_PORT=1025
N8N_SMTP_USER=
N8N_SMTP_PASS=
N8N_SMTP_SENDER=n8n@micuota.local
N8N_SMTP_SSL=false

# CRM interno MVP para n8n
APP_CRM_API_KEY=change-this-crm-key
APP_CRM_DEFAULT_OWNER=ventas@micuota.online
CRM_BASE_URL=http://localhost:8080/api/crm
CRM_API_KEY=${APP_CRM_API_KEY}
