# Copia este archivo a .env.prod y ajusta valores para tu entorno
SPRING_PROFILES_ACTIVE=prod
DB_URL=jdbc:postgresql://localhost:5432/micuota
DB_USERNAME=micuota
DB_PASSWORD=micuota

# SMTP (opcional para enviar mails reales de pago)
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@micuota.online
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true

# Para pruebas locales con Mailpit puedes usar:
# MAIL_HOST=localhost
# MAIL_PORT=1025
# MAIL_SMTP_AUTH=false
# MAIL_SMTP_STARTTLS=false

# Integraciones de links de pago (Stripe, Square, Plexo)
# Si queda en false, el backend usa checkout sandbox interno para estos providers.
APP_PAYMENTS_EXTERNAL_PROVIDERS_ENABLED=false

# Stripe Payment Links
APP_PAYMENTS_STRIPE_SECRET_KEY=

# Square Payment Links
APP_PAYMENTS_SQUARE_ACCESS_TOKEN=
APP_PAYMENTS_SQUARE_LOCATION_ID=
APP_PAYMENTS_SQUARE_USE_SANDBOX=true

# Plexo Links (endpoint configurable)
APP_PAYMENTS_PLEXO_API_URL=
APP_PAYMENTS_PLEXO_API_KEY=
