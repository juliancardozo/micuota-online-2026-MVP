    {
      "name": "01 - Tenant Onboarding (Admin)",
      "item": [
        {
          "name": "POST Register Tenant",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const stamp = Date.now().toString();",
                  "pm.collectionVariables.set('tenantSlug', `tenant-postman-${stamp}`);",
                  "pm.collectionVariables.set('adminEmail', `admin.postman+${stamp}@micuota.online`);",
                  "pm.collectionVariables.set('teacherEmail', `teacher.postman+${stamp}@micuota.online`);",
                  "pm.collectionVariables.set('studentEmail', `student.postman+${stamp}@micuota.online`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('tenantAdminToken', json.token);",
                  "pm.collectionVariables.set('tenantId', String(json.tenantId));",
                  "pm.collectionVariables.set('tenantSlug', json.tenantSlug);",
                  "pm.test('Token presente', function () { pm.expect(json.token).to.be.a('string').and.not.empty; });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantName\": \"Tenant Postman\",\n  \"tenantSlug\": \"{{tenantSlug}}\",\n  \"fullName\": \"Admin Postman\",\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\",\n  \"mpAccessToken\": \"TEST-MP-TOKEN-POSTMAN\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register-tenant",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register-tenant"]
            }
          },
          "response": []
        },
        {
          "name": "GET Auth Me (Admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Auth-Token", "value": "{{tenantAdminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            }
          },
          "response": []
        }
      ]
